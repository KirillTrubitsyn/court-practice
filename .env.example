# Скопируй в .env и заполни.

# === Обязательные ===
# Voyage AI key для семантического слоя.
VOYAGE_API_KEY=pa-...

# Bearer token для аутентификации MCP-клиентов. Сгенерируй:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_SECRET_KEY=replace-me-min-32-chars

# === Хранилища ===
# Redis для кэша эмбеддингов запросов. Railway даёт REDIS_URL автоматически.
REDIS_URL=redis://localhost:6379/0

# Где лежат index.pkl.gz и embeddings.npy. На Railway монтируем Volume в /data.
DATA_DIR=./data

# Если true — при старте перезатереть index.pkl.gz и embeddings.npy дефолтными
# из репо. Использовать однократно после обновления схемы индекса (multi-id dedup).
# После успешного запуска выставить обратно в false (или удалить переменную).
# FORCE_RESEED_DATA=false

# === Voyage ===
VOYAGE_MODEL=voyage-3-large
VOYAGE_EMBED_DIM=1024
VOYAGE_BATCH_SIZE=32
VOYAGE_TIMEOUT_S=30.0

# === Кэш ===
CACHE_TTL_DAYS=30

# === Веса гибридного поиска (RRF) ===
RRF_K=60
BM25_WEIGHT=1.0
SEMANTIC_WEIGHT=1.0

# === Веса секций BM25 (опционально, переопределяют дефолты reference) ===
# Если не задано — используются: title=3, vs_position=3, full=1, fabula=0.7, tags=5.
# SECTION_WEIGHT_TITLE=3.0
# SECTION_WEIGHT_VS_POSITION=3.0
# SECTION_WEIGHT_FULL=1.0
# SECTION_WEIGHT_FABULA=0.7
# SECTION_WEIGHT_TAGS=5.0

# === Безопасность MCP-транспорта ===
# По умолчанию выключено — за Railway HTTPS-edge не нужно.
# Если включаешь — обязательно укажи allowed_hosts.
# MCP_ENABLE_DNS_REBINDING_PROTECTION=false
# MCP_ALLOWED_HOSTS=web-production-xxxx.up.railway.app,localhost:8000
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://localhost:*

# === OAuth (multi-user через shared password) ===
# Если задан — claude.ai web сможет подключиться через OAuth flow:
# каждый коллега вводит этот пароль на форме авторизации (как Wi-Fi).
# Без этой переменной OAuth flow выключен, работает только static Bearer
# (для Claude Desktop/Code).
# MCP_AUTH_PASSWORD=

# Публичный URL сервиса (для OAuth metadata за прокси). Обычно не нужен,
# Railway корректно проставляет Host header.
# PUBLIC_BASE_URL=https://web-production-xxxx.up.railway.app

# TTL access_token (JWT) и refresh_token. По умолчанию 24h / 30d.
# OAUTH_ACCESS_TOKEN_TTL_S=86400
# OAUTH_REFRESH_TOKEN_TTL_S=2592000
# OAUTH_AUTHORIZATION_CODE_TTL_S=120

# === Прочее ===
LOG_LEVEL=INFO
PORT=8000
